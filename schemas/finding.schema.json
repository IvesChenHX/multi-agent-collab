{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/multi-agent-collab/schemas/finding.schema.json",
  "title": "Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "task_id",
    "severity",
    "category",
    "blocking_effect",
    "confidence",
    "status",
    "title",
    "risk",
    "owner",
    "opened_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "task_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "severity": {
      "$ref": "common.schema.json#/$defs/severity"
    },
    "category": {
      "$ref": "common.schema.json#/$defs/finding_category"
    },
    "blocking_effect": {
      "enum": [
        "block_close",
        "waiver_allowed",
        "advisory"
      ]
    },
    "confidence": {
      "enum": [
        "confirmed",
        "high",
        "medium",
        "low"
      ]
    },
    "status": {
      "enum": [
        "open",
        "fixing",
        "resolved",
        "waived",
        "obsolete"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "common.schema.json#/$defs/repo_path"
        },
        "line_start": {
          "type": "integer",
          "minimum": 1
        },
        "line_end": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "invalidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "root_cause_key": {
      "type": "string"
    },
    "opened_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "resolved_at": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
