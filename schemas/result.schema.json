{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/multi-agent-collab/schemas/result.schema.json",
  "title": "Agent/run result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "task_id",
    "work_unit_id",
    "run_id",
    "outcome",
    "summary",
    "changed_files",
    "commands",
    "submitted_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "task_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "work_unit_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "outcome": {
      "enum": [
        "succeeded",
        "failed",
        "blocked",
        "partial"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/repo_path"
      },
      "uniqueItems": true
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "argv",
          "exit_code"
        ],
        "properties": {
          "argv": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "exit_code": {
            "type": "integer"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "new_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope_amendment_request": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/glob_path"
          }
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "raw_log_ref": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "common.schema.json#/$defs/repo_path"
        },
        "digest": {
          "$ref": "common.schema.json#/$defs/digest"
        }
      }
    },
    "submitted_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    }
  }
}
