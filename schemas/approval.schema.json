{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/multi-agent-collab/schemas/approval.schema.json",
  "title": "Approval",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "task_id",
    "kind",
    "actor",
    "decision",
    "subject_ref",
    "independence_level",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "task_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "kind": {
      "enum": [
        "scope",
        "policy_rebase",
        "risk_acceptance",
        "close",
        "manual_gate"
      ]
    },
    "actor": {
      "$ref": "common.schema.json#/$defs/actor"
    },
    "decision": {
      "enum": [
        "approved",
        "rejected"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "independence_level": {
      "$ref": "common.schema.json#/$defs/independence_level"
    },
    "comment": {
      "type": "string"
    },
    "recorded_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scheme": {
          "enum": [
            "sigstore",
            "gpg",
            "none"
          ]
        },
        "digest": {
          "$ref": "common.schema.json#/$defs/digest"
        }
      }
    }
  }
}
