{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/multi-agent-collab/schemas/work-unit.schema.json",
  "title": "Work unit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "task_id",
    "title",
    "status",
    "owner",
    "allowed_paths",
    "depends_on",
    "expected_result"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "task_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "pending",
        "ready",
        "running",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "executor_role": {
      "type": "string"
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/glob_path"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_result": {
      "$ref": "common.schema.json#/$defs/repo_path"
    }
  }
}
