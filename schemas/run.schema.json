{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/multi-agent-collab/schemas/run.schema.json",
  "title": "Execution run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "task_id",
    "work_unit_id",
    "status",
    "actor",
    "runtime",
    "independence_level",
    "started_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "task_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "work_unit_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "registered",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "unknown"
      ]
    },
    "actor": {
      "$ref": "common.schema.json#/$defs/actor"
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "execution_context_id"
      ],
      "properties": {
        "profile": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "execution_context_id": {
          "$ref": "common.schema.json#/$defs/simple_id"
        },
        "worktree": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        }
      }
    },
    "independence_level": {
      "$ref": "common.schema.json#/$defs/independence_level"
    },
    "started_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "finished_at": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "max_output_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "independence_attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "commit_participation"
      ],
      "properties": {
        "read_only": {
          "type": "boolean"
        },
        "commit_participation": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/git_sha"
          },
          "uniqueItems": true
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "independence_level": {
            "enum": ["L2", "L3"]
          }
        },
        "required": ["independence_level"]
      },
      "then": {
        "required": ["independence_attestation"],
        "properties": {
          "runtime": {
            "required": ["profile", "provider", "model", "execution_context_id"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "independence_level": {"const": "L3"}
        },
        "required": ["independence_level"]
      },
      "then": {
        "properties": {
          "actor": {
            "properties": {
              "kind": {"const": "human"}
            }
          }
        }
      }
    }
  ]
}
