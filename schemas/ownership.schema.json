{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/multi-agent-collab/schemas/ownership.schema.json",
  "title": "Ownership mapping",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "matching",
    "owners"
  ],
  "properties": {
    "schema_version": {
      "const": 6
    },
    "matching": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantics",
        "ambiguous",
        "unassigned"
      ],
      "properties": {
        "semantics": {
          "const": "gitwildmatch"
        },
        "ambiguous": {
          "enum": [
            "error",
            "require_triage"
          ]
        },
        "unassigned": {
          "enum": [
            "error",
            "require_triage"
          ]
        },
        "case_sensitive": {
          "enum": [
            "auto",
            true,
            false
          ]
        }
      }
    },
    "owners": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "include",
          "implementation_role"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "implementation_role": {
            "type": "string",
            "minLength": 1
          },
          "include": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "common.schema.json#/$defs/glob_path"
            },
            "uniqueItems": true
          },
          "exclude": {
            "type": "array",
            "items": {
              "$ref": "common.schema.json#/$defs/glob_path"
            },
            "uniqueItems": true
          },
          "approvers": {
            "$ref": "common.schema.json#/$defs/string_list"
          },
          "coowners": {
            "$ref": "common.schema.json#/$defs/string_list"
          }
        }
      }
    },
    "sensitive_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pattern",
          "risk_tags"
        ],
        "properties": {
          "pattern": {
            "$ref": "common.schema.json#/$defs/glob_path"
          },
          "risk_tags": {
            "$ref": "common.schema.json#/$defs/string_list"
          },
          "required_gates": {
            "$ref": "common.schema.json#/$defs/string_list"
          }
        }
      }
    }
  }
}
